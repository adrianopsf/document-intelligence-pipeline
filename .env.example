# =============================================================================
# Document Intelligence Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://docai:docai_secret@localhost:5432/docai
DATABASE_URL_SYNC=postgresql://docai:docai_secret@localhost:5432/docai

# --- Qdrant Vector Store ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=docai_chunks

# --- LLM Provider (OpenAI-compatible) ---
# Works with: OpenAI, Ollama (http://localhost:11434/v1), vLLM, LiteLLM, etc.
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Embedding ---
# Local model (no API key needed): all-MiniLM-L6-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- OCR ---
# Path to Tesseract binary (auto-detected on most systems)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- App Settings ---
APP_NAME=Document Intelligence Pipeline
APP_VERSION=0.1.0
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]
